{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "declaration": true,
    "rootDir": "src",
    "outDir": "dist",
    "skipLibCheck": true,
    "paths": {
      "pumpkin:plugin/*": ["./src/gen/interfaces/pumpkin-plugin-*"]
    }
  },
  "include": ["src/**/*"]
}
