{
  "name": "@pumpkinmc/pumpkin-api-ts",
  "version": "0.1.0-dev1",
  "description": "Pumpkin plugin API for TypeScript",
  "main": "dist/index.ts",
  "types": "dist/index.ts",
  "files": [
    "dist",
    "src/build.js",
